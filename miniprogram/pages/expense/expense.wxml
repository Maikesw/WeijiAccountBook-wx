<!-- 记账页 - 优化版本 -->
<view class="page-container">
  <!-- 金额输入区 -->
  <view class="amount-section card">
    <view class="amount-label">金额</view>
    <view class="amount-input-wrap">
      <text class="currency">¥</text>
      <input class="amount-input" type="digit" placeholder="0.00" 
             value="{{amount}}" bindinput="onAmountInput" focus="{{true}}"/>
    </view>
    <view class="quick-amounts" wx:if="{{!isEditMode}}">
      <text wx:for="{{quickAmounts}}" wx:key="*this" class="quick-amount-tag" 
            bindtap="setQuickAmount" data-amount="{{item}}">{{item}}</text>
    </view>
  </view>

  <!-- 收支类型切换 -->
  <view class="type-section card">
    <view class="type-switch">
      <view class="type-option {{type === 'expense' ? 'type-active expense-active' : ''}}" 
            bindtap="switchType" data-type="expense">
        <text class="type-icon">📤</text>
        <text class="type-text">支出</text>
      </view>
      <view class="type-option {{type === 'income' ? 'type-active income-active' : ''}}" 
            bindtap="switchType" data-type="income">
        <text class="type-icon">📥</text>
        <text class="type-text">收入</text>
      </view>
    </view>
  </view>

  <!-- 分类选择 -->
  <view class="category-section card">
    <view class="section-header">
      <text class="section-title">分类</text>
      <text class="selected-category" wx:if="{{selectedCategory}}">{{selectedCategory}}</text>
    </view>
    <view class="category-grid">
      <view wx:for="{{categories}}" wx:key="name" 
            class="category-item {{selectedCategory === item.name ? 'category-active' : ''}}"
            bindtap="selectCategory" data-category="{{item}}"
            style="{{selectedCategory === item.name ? 'background:' + item.color + '20; border-color:' + item.color : ''}}">
        <text class="category-icon" style="background: {{item.bgColor}};">{{item.icon}}</text>
        <text class="category-name">{{item.name}}</text>
      </view>
    </view>
  </view>

  <!-- 日期选择 -->
  <view class="form-section card">
    <view class="form-item">
      <text class="form-label">日期</text>
      <picker mode="date" value="{{spentAt}}" end="{{today}}" bindchange="onDateChange">
        <view class="form-value">
          <text>{{spentAtDisplay}}</text>
          <text class="form-arrow">›</text>
        </view>
      </picker>
    </view>
    
    <view class="divider"></view>
    
    <view class="form-item">
      <text class="form-label">备注</text>
      <input class="form-input" placeholder="添加备注（可选）" 
             value="{{remark}}" bindinput="onRemarkInput"/>
    </view>
  </view>

  <!-- 关联存钱目标 -->
  <view class="goal-section card" wx:if="{{savingsGoals.length > 0}}">
    <view class="section-header">
      <text class="section-title">关联存钱目标</text>
      <switch checked="{{linkGoal}}" bindchange="toggleLinkGoal" color="#1677FF"/>
    </view>
    <view class="goal-list" wx:if="{{linkGoal}}">
      <view wx:for="{{savingsGoals}}" wx:key="name" 
            class="goal-item {{selectedGoal === item.name ? 'goal-active' : ''}}"
            bindtap="selectGoal" data-goal="{{item}}">
        <text class="goal-icon">🎯</text>
        <view class="goal-info">
          <text class="goal-name">{{item.name}}</text>
          <text class="goal-progress">进度 {{item.progress}}%</text>
        </view>
        <view class="goal-radio {{selectedGoal === item.name ? 'radio-checked' : ''}}">
          <view class="radio-inner" wx:if="{{selectedGoal === item.name}}"></view>
        </view>
      </view>
    </view>
  </view>

  <!-- 保存按钮 -->
  <view class="action-bar">
    <button wx:if="{{isEditMode}}" class="btn btn-secondary delete-btn" bindtap="onDelete">
      删除
    </button>
    <button class="btn btn-primary save-btn {{!canSubmit ? 'btn-disabled' : ''}}" bindtap="onSubmit">
      {{isEditMode ? '保存修改' : '保存'}}
    </button>
  </view>

  <!-- 底部安全区域 -->
  <view style="height: 40rpx;"></view>
</view>
