/* 统计页 - 优化样式 */

.page-container {
  padding: var(--space-sm);
  padding-bottom: 40rpx;
}

/* 筛选栏 */
.filter-bar {
  padding: var(--space-sm);
  margin-bottom: var(--space-sm);
}

.time-tabs {
  display: flex;
  background: var(--neutral-100);
  border-radius: var(--radius-sm);
  padding: 6rpx;
}

.time-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  color: var(--neutral-700);
  border-radius: var(--radius-sm);
  transition: all 200ms ease;
}

.time-tab.tab-active {
  background: var(--neutral-0);
  color: var(--primary-600);
  font-weight: 600;
  box-shadow: var(--shadow-sm);
}

.custom-date {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: var(--space-sm);
  padding: 16rpx;
  background: var(--neutral-100);
  border-radius: var(--radius-sm);
  font-size: 28rpx;
  color: var(--neutral-700);
}

.custom-date .arrow {
  font-size: 20rpx;
  margin-left: 12rpx;
}

/* 核心数据卡片 */
.summary-cards {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-sm);
  margin-bottom: var(--space-md);
}

.summary-card {
  background: var(--neutral-0);
  border-radius: var(--radius-md);
  padding: var(--space-md);
  box-shadow: var(--shadow-sm);
  text-align: center;
}

.summary-label {
  font-size: 24rpx;
  color: var(--neutral-500);
  display: block;
  margin-bottom: 12rpx;
}

.summary-value {
  font-size: 32rpx;
  font-weight: 700;
  display: inline-block;
  line-height: 1.2;
  white-space: nowrap;
}

.summary-value::before {
  content: '¥';
  font-size: 24rpx;
  font-weight: 500;
  margin-right: 2rpx;
  white-space: nowrap;
}

.income-card .summary-value {
  color: var(--success-600);
}

.expense-card .summary-value {
  color: var(--error-600);
}

.balance-card .summary-value {
  color: var(--neutral-900);
}

/* 图表区 */
.chart-section {
  padding: var(--space-md);
  margin-bottom: var(--space-md);
}

.chart-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--space-md);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--neutral-900);
}

.chart-legend {
  display: flex;
  gap: var(--space-sm);
}

.legend-item {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: var(--neutral-500);
}

.legend-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: var(--radius-full);
  margin-right: 8rpx;
}

.chart-container {
  height: 400rpx;
}

.trend-chart {
  width: 100%;
  height: 100%;
}

/* 饼图 */
.pie-chart-container {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.pie-chart {
  width: 400rpx;
  height: 400rpx;
  margin-bottom: var(--space-md);
}

.pie-legend {
  width: 100%;
}

.pie-legend-item {
  display: flex;
  align-items: center;
  padding: var(--space-xs) 0;
}

.legend-color {
  width: 24rpx;
  height: 24rpx;
  border-radius: var(--radius-full);
  margin-right: var(--space-sm);
  flex-shrink: 0;
}

.legend-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.legend-name {
  font-size: 28rpx;
  color: var(--neutral-700);
}

.legend-percent {
  font-size: 22rpx;
  color: var(--neutral-500);
}

.legend-amount {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--neutral-900);
}

/* 饼图空状态 */
.pie-empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
}

.pie-empty-icon {
  font-size: 96rpx;
  margin-bottom: var(--space-sm);
}

.pie-empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--neutral-700);
  margin-bottom: var(--space-xs);
}

.pie-empty-desc {
  font-size: 26rpx;
  color: var(--neutral-500);
  margin-bottom: var(--space-sm);
}

/* 明细区 */
.detail-section {
  padding: var(--space-md);
}

.detail-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--space-md);
}

.detail-count {
  font-size: 24rpx;
  color: var(--neutral-500);
}

.detail-list {
  border-top: 2rpx solid var(--neutral-100);
}

.detail-item {
  display: flex;
  align-items: center;
  padding: var(--space-sm) 0;
  border-bottom: 2rpx solid var(--neutral-100);
}

.detail-item:last-child {
  border-bottom: none;
}

.detail-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: var(--space-sm);
  flex-shrink: 0;
}

.detail-info {
  flex: 1;
  min-width: 0;
}

.detail-name {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--neutral-900);
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.detail-date {
  font-size: 24rpx;
  color: var(--neutral-500);
  margin-top: 4rpx;
  display: block;
}

.detail-amount {
  margin-left: var(--space-sm);
}

.amount-value {
  font-size: 32rpx;
  font-weight: 600;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: var(--space-sm) 0;
  border-top: 2rpx solid var(--neutral-100);
}

.load-more text {
  font-size: 26rpx;
  color: var(--primary-600);
}

.no-more {
  text-align: center;
  padding: var(--space-sm) 0;
}

.no-more text {
  font-size: 24rpx;
  color: var(--neutral-400);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--space-xl);
  margin-top: var(--space-md);
}

.empty-icon-text {
  font-size: 96rpx;
  margin-bottom: var(--space-sm);
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--neutral-700);
  margin-bottom: var(--space-xs);
}

.empty-desc {
  font-size: 26rpx;
  color: var(--neutral-500);
}

/* 文字工具类 */
.text-income {
  color: var(--success-600);
}

.text-expense {
  color: var(--error-600);
}
