<!-- 个人中心 - 优化版本 -->
<view class="page-container">
  <!-- 用户信息卡片 -->
  <view class="user-card">
    <view class="user-header">
      <view class="user-avatar">
        <open-data type="userAvatarUrl"></open-data>
      </view>
      <view class="user-info">
        <open-data type="userNickName" class="user-name"></open-data>
        <text class="user-id" wx:if="{{userInfo.openid}}">ID: {{userInfo.openid}}</text>
      </view>
    </view>
    
    <view class="user-stats">
      <view class="stat-item">
        <text class="stat-value">{{userStats.totalDays}}</text>
        <text class="stat-label">记账天数</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-value">{{userStats.totalRecords}}</text>
        <text class="stat-label">总账单</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-value">{{userStats.totalStories}}</text>
        <text class="stat-label">财记数</text>
      </view>
    </view>
  </view>

  <!-- 数据安全中心 -->
  <view class="security-bar" bindtap="goToSecurity">
    <view class="security-left">
      <text class="security-icon">🔒</text>
      <text class="security-text">数据安全中心</text>
    </view>
    <text class="security-arrow">›</text>
  </view>

  <!-- 功能列表 -->
  <view class="section-block">
    <text class="section-title">我的功能</text>
    <view class="func-list">
      <view class="func-item" bindtap="goToGoals">
        <view class="func-icon" style="background: #E6F4FF;">
          <text style="color: #1677FF;">🎯</text>
        </view>
        <text class="func-name">存钱目标</text>
        <text class="func-arrow">›</text>
      </view>
      <view class="func-item" bindtap="goToBudget">
        <view class="func-icon" style="background: #FFF7E8;">
          <text style="color: #FF7D00;">💰</text>
        </view>
        <text class="func-name">预算设置</text>
        <text class="func-arrow">›</text>
      </view>
      <view class="func-item" bindtap="goToCategories">
        <view class="func-icon" style="background: #F0F5FF;">
          <text style="color: #165DFF;">🏷️</text>
        </view>
        <text class="func-name">分类管理</text>
        <text class="func-arrow">›</text>
      </view>
      <view class="func-item" bindtap="backupData">
        <view class="func-icon" style="background: #E8FFEA;">
          <text style="color: #00B42A;">💾</text>
        </view>
        <text class="func-name">数据备份</text>
        <text class="func-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 系统设置 -->
  <view class="section-block">
    <text class="section-title">系统设置</text>
    <view class="func-list">
      <view class="func-item">
        <view class="func-icon" style="background: #F5F7FA;">
          <text style="color: #86909C;">🌙</text>
        </view>
        <text class="func-name">深色模式</text>
        <switch checked="{{darkMode}}" bindchange="toggleDarkMode" color="#1677FF"/>
      </view>
      <view class="func-item" bindtap="adjustFontSize">
        <view class="func-icon" style="background: #F5F7FA;">
          <text style="color: #86909C;">🔤</text>
        </view>
        <text class="func-name">字体大小</text>
        <text class="func-value">{{fontSizeLabel}}</text>
        <text class="func-arrow">›</text>
      </view>
      <view class="func-item" bindtap="goToNotification">
        <view class="func-icon" style="background: #F5F7FA;">
          <text style="color: #86909C;">🔔</text>
        </view>
        <text class="func-name">通知设置</text>
        <text class="func-arrow">›</text>
      </view>
      <view class="func-item" bindtap="clearCache">
        <view class="func-icon" style="background: #F5F7FA;">
          <text style="color: #86909C;">🗑️</text>
        </view>
        <text class="func-name">清理缓存</text>
        <text class="func-value">{{cacheSize}}</text>
        <text class="func-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 帮助与反馈 -->
  <view class="section-block">
    <text class="section-title">帮助与反馈</text>
    <view class="func-list">
      <view class="func-item" bindtap="showHelp">
        <view class="func-icon" style="background: #F5F7FA;">
          <text style="color: #86909C;">❓</text>
        </view>
        <text class="func-name">常见问题</text>
        <text class="func-arrow">›</text>
      </view>
      <view class="func-item" bindtap="feedback">
        <view class="func-icon" style="background: #F5F7FA;">
          <text style="color: #86909C;">✉️</text>
        </view>
        <text class="func-name">意见反馈</text>
        <text class="func-arrow">›</text>
      </view>
      <view class="func-item" bindtap="showAbout">
        <view class="func-icon" style="background: #F5F7FA;">
          <text style="color: #86909C;">ℹ️</text>
        </view>
        <text class="func-name">关于我们</text>
        <text class="func-value">v1.0.0</text>
        <text class="func-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 危险操作区 -->
  <view class="danger-zone">
    <button class="btn-danger" bindtap="clearAllData">清空所有数据</button>
  </view>

  <!-- 底部信息 -->
  <view class="footer">
    <text class="footer-links">
      <text bindtap="showPrivacy">隐私政策</text>
      <text class="divider">|</text>
      <text bindtap="showAgreement">用户协议</text>
    </text>
    <text class="footer-copyright">© 2024 理财日记</text>
  </view>

  <!-- 底部安全区域 -->
  <view style="height: 40rpx;"></view>
</view>

<!-- 字体大小选择弹窗 -->
<view class="modal {{showFontModal ? 'modal-show' : ''}}" bindtap="hideFontModal">
  <view class="modal-content" catchtap="stopPropagation">
    <view class="modal-header">
      <text class="modal-title">字体大小</text>
      <text class="modal-close" bindtap="hideFontModal">×</text>
    </view>
    <view class="font-options">
      <view wx:for="{{fontOptions}}" wx:key="value" 
            class="font-option {{fontSize === item.value ? 'font-active' : ''}}"
            bindtap="setFontSize" data-size="{{item.value}}">
        <text class="font-preview" style="font-size: {{item.previewSize}}rpx;">Aa</text>
        <text class="font-label">{{item.label}}</text>
        <view class="check-icon" wx:if="{{fontSize === item.value}}">✓</view>
      </view>
    </view>
  </view>
</view>
