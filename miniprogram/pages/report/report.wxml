<!-- 统计页 - 优化版本 -->
<view class="page-container">
  <!-- 时间筛选 -->
  <view class="filter-bar card">
    <view class="time-tabs">
      <view wx:for="{{timeTabs}}" wx:key="value" 
            class="time-tab {{currentTimeTab === item.value ? 'tab-active' : ''}}"
            bindtap="switchTimeTab" data-tab="{{item.value}}">
        {{item.label}}
      </view>
    </view>
    <picker wx:if="{{currentTimeTab === 'custom'}}" mode="date" fields="month" 
            value="{{currentDate}}" end="{{today}}" bindchange="onDateChange">
      <view class="custom-date">
        <text>{{currentYear}}-{{currentMonth}}</text>
        <text class="arrow">▼</text>
      </view>
    </picker>
  </view>

  <!-- 核心数据概览 -->
  <view class="summary-cards">
    <view class="summary-card income-card">
      <text class="summary-label">总收入</text>
      <text class="summary-value text-income">+{{stats.income}}</text>
    </view>
    <view class="summary-card expense-card">
      <text class="summary-label">总支出</text>
      <text class="summary-value text-expense">-{{stats.expense}}</text>
    </view>
    <view class="summary-card balance-card">
      <text class="summary-label">结余</text>
      <text class="summary-value {{stats.balance >= 0 ? 'text-income' : 'text-expense'}}">
        {{stats.balance >= 0 ? '+' : ''}}{{stats.balance}}
      </text>
    </view>
  </view>

  <!-- 图表区 -->
  <view class="chart-section card">
    <view class="chart-header">
      <text class="section-title">收支趋势</text>
      <view class="chart-legend">
        <view class="legend-item">
          <view class="legend-dot" style="background: var(--success-600);"></view>
          <text>收入</text>
        </view>
        <view class="legend-item">
          <view class="legend-dot" style="background: var(--error-600);"></view>
          <text>支出</text>
        </view>
      </view>
    </view>
    <view class="chart-container">
      <canvas type="2d" id="trendChart" class="trend-chart"></canvas>
    </view>
  </view>

  <!-- 支出占比饼图 -->
  <view class="chart-section card">
    <view class="chart-header">
      <text class="section-title">支出占比</text>
    </view>
    
    <!-- 有数据时显示饼图 -->
    <view wx:if="{{categoryStats.length > 0}}" class="pie-chart-container">
      <canvas type="2d" id="pieChart" class="pie-chart"></canvas>
      <view class="pie-legend">
        <view wx:for="{{categoryStats}}" wx:key="name" class="pie-legend-item">
          <view class="legend-color" style="background: {{item.color}};"></view>
          <view class="legend-info">
            <text class="legend-name">{{item.name}}</text>
            <text class="legend-percent">{{item.percent}}%</text>
          </view>
          <text class="legend-amount">{{item.amount}}</text>
        </view>
      </view>
    </view>
    
    <!-- 无数据时显示空状态 -->
    <view wx:if="{{categoryStats.length === 0}}" class="pie-empty-state">
      <text class="pie-empty-icon">🍩</text>
      <text class="pie-empty-title">暂无支出数据</text>
      <text class="pie-empty-desc">该时间段内没有支出记录</text>
      <button class="btn btn-primary" style="margin-top: 24rpx; width: 240rpx;" bindtap="goAdd">
        记一笔
      </button>
    </view>
  </view>

  <!-- 账单明细 -->
  <view class="detail-section card">
    <view class="detail-header">
      <text class="section-title">账单明细</text>
      <text class="detail-count">共{{detailList.length}}笔</text>
    </view>
    
    <view class="detail-list">
      <view wx:for="{{detailList}}" wx:key="_id" class="detail-item" bindtap="viewDetail" data-id="{{item._id}}">
        <view class="detail-icon" style="background: {{item.bgColor}};">
          <text>{{item.icon}}</text>
        </view>
        <view class="detail-info">
          <text class="detail-name">{{item.event || item.category}}</text>
          <text class="detail-date">{{item.displayDate}}</text>
        </view>
        <view class="detail-amount">
          <text class="amount-value {{item.type === 'income' ? 'text-income' : 'text-expense'}}">
            {{item.type === 'income' ? '+' : '-'}}{{item.amount}}
          </text>
        </view>
      </view>
    </view>
    
    <!-- 加载更多 -->
    <view class="load-more" wx:if="{{hasMore}}" bindtap="loadMore">
      <text>加载更多</text>
    </view>
    <view class="no-more" wx:if="{{!hasMore && detailList.length > 0}}">
      <text>已加载全部</text>
    </view>
  </view>

  <!-- 空状态 -->
  <view wx:if="{{detailList.length === 0 && !loading}}" class="empty-state card">
    <text class="empty-icon-text">📊</text>
    <text class="empty-title">暂无账单数据</text>
    <text class="empty-desc">该时间段内没有收支记录</text>
    <button class="btn btn-primary" style="margin-top: 32rpx; width: 300rpx;" bindtap="goAdd">
      记一笔
    </button>
  </view>

  <!-- 底部安全区域 -->
  <view style="height: 40rpx;"></view>
</view>
