/* 个人中心 - 优化样式 */

.page-container {
  padding: 16rpx;
  padding-bottom: 40rpx;
}

/* 用户信息卡片 */
.user-card {
  background: linear-gradient(135deg, #1677FF 0%, #4096FF 100%);
  border-radius: 12rpx;
  padding: 32rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(29, 33, 41, 0.12);
}

.user-header {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 9999rpx;
  overflow: hidden;
  margin-right: 24rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  background: rgba(255, 255, 255, 0.2);
}

.user-avatar open-data {
  width: 100%;
  height: 100%;
}

.user-name {
  font-size: 40rpx;
  font-weight: 600;
  color: #FFFFFF;
  display: block;
  margin-bottom: 8rpx;
}

.user-id {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 用户统计 */
.user-stats {
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding-top: 24rpx;
  border-top: 2rpx solid rgba(255, 255, 255, 0.2);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.2);
}

/* 安全中心入口 */
.security-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background: #FFFFFF;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(29, 33, 41, 0.08);
}

.security-left {
  display: flex;
  align-items: center;
}

.security-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.security-text {
  font-size: 30rpx;
  font-weight: 500;
  color: #1D2129;
}

.security-arrow {
  font-size: 36rpx;
  color: #A9AEB8;
}

/* 区块标题 */
.section-block {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #86909C;
  margin-bottom: 16rpx;
  margin-left: 8rpx;
  display: block;
}

/* 功能列表 */
.func-list {
  background: #FFFFFF;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(29, 33, 41, 0.08);
  overflow: hidden;
}

.func-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 2rpx solid #F5F7FA;
  transition: all 200ms ease;
}

.func-item:last-child {
  border-bottom: none;
}

.func-item:active {
  background: #F5F7FA;
}

.func-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.func-name {
  flex: 1;
  font-size: 30rpx;
  color: #1D2129;
}

.func-value {
  font-size: 26rpx;
  color: #86909C;
  margin-right: 16rpx;
}

.func-arrow {
  font-size: 36rpx;
  color: #A9AEB8;
}

/* Switch样式 */
.func-item switch {
  margin-left: auto;
}

/* 危险操作区 */
.danger-zone {
  margin-top: 32rpx;
  margin-bottom: 24rpx;
}

.btn-danger {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: transparent;
  border: 2rpx solid #F53F3F;
  color: #F53F3F;
  font-size: 30rpx;
  border-radius: 8rpx;
}

.btn-danger::after {
  border: none;
}

.btn-danger:active {
  background: #FFECE8;
}

/* 底部信息 */
.footer {
  text-align: center;
  padding: 24rpx 0;
}

.footer-links {
  font-size: 26rpx;
  color: #1677FF;
  margin-bottom: 8rpx;
  display: block;
}

.footer-links text {
  margin: 0 8rpx;
}

.footer-links .divider {
  color: #C9CDD4;
}

.footer-copyright {
  font-size: 22rpx;
  color: #A9AEB8;
}

/* 弹窗 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  opacity: 0;
  visibility: hidden;
  transition: all 300ms ease;
  z-index: 1000;
}

.modal-show {
  opacity: 1;
  visibility: visible;
}

.modal-content {
  width: 100%;
  max-height: 80vh;
  background: #FFFFFF;
  border-radius: 16rpx 16rpx 0 0;
  padding: 24rpx;
  transform: translateY(100%);
  transition: transform 300ms ease;
}

.modal-show .modal-content {
  transform: translateY(0);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1D2129;
}

.modal-close {
  font-size: 48rpx;
  color: #A9AEB8;
  padding: 0 16rpx;
}

/* 字体选项 */
.font-options {
  padding-bottom: 24rpx;
}

.font-option {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #F5F7FA;
  border-radius: 8rpx;
  margin-bottom: 16rpx;
  transition: all 200ms ease;
}

.font-option:active {
  opacity: 0.8;
}

.font-active {
  background: #E6F4FF;
  border: 2rpx solid #1677FF;
}

.font-preview {
  font-weight: 600;
  color: #1D2129;
  margin-right: 24rpx;
  width: 80rpx;
  text-align: center;
}

.font-label {
  flex: 1;
  font-size: 30rpx;
  color: #4E5969;
}

.check-icon {
  width: 48rpx;
  height: 48rpx;
  background: #1677FF;
  border-radius: 9999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 600;
}
