/* 账本页 - 优化样式 */

.page-container {
  padding: var(--space-sm);
  padding-bottom: 160rpx;
}

/* 日期选择器 */
.date-selector {
  background: linear-gradient(135deg, var(--primary-600) 0%, var(--primary-500) 100%);
  color: var(--neutral-0);
}

.date-selector .text-caption {
  color: rgba(255, 255, 255, 0.8);
  font-size: 24rpx;
}

.date-selector .text-h2 {
  color: var(--neutral-0);
  font-size: 40rpx;
}

.arrow-icon {
  color: rgba(255, 255, 255, 0.8);
  font-size: 24rpx;
}

.date-icon {
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: var(--radius-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

/* 核心数据双卡片 */
.core-cards {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-sm);
  margin-bottom: var(--space-md);
}

.core-card {
  background: var(--neutral-0);
  border-radius: var(--radius-md);
  padding: var(--space-md);
  box-shadow: var(--shadow-sm);
}

.card-label {
  font-size: 24rpx;
  color: var(--neutral-500);
  margin-bottom: var(--space-xs);
  display: block;
}

.amount-display {
  margin-bottom: var(--space-xs);
}

.amount-main {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--neutral-900);
}

.amount-main::before {
  content: '¥';
  font-size: 28rpx;
  font-weight: 500;
  margin-right: 4rpx;
}

.amount-sub {
  display: flex;
  gap: var(--space-sm);
  font-size: 22rpx;
}

.income-sub {
  color: var(--success-600);
}

.expense-sub {
  color: var(--error-600);
}

/* 预算卡片 */
.budget-amount {
  margin-bottom: var(--space-xs);
}

.budget-amount .amount-main {
  font-size: 36rpx;
}

.progress-container {
  margin-top: 8rpx;
}

.progress-bar {
  height: 12rpx;
  background: var(--neutral-200);
  border-radius: var(--radius-full);
  overflow: hidden;
  margin-bottom: 8rpx;
}

.progress-fill {
  height: 100%;
  border-radius: var(--radius-full);
  transition: width 300ms ease;
}

.progress-fill.success {
  background: var(--success-600);
}

.progress-fill.warning {
  background: var(--warning-600);
}

.progress-fill.error {
  background: var(--error-600);
}

.progress-text {
  font-size: 20rpx;
  color: var(--neutral-500);
}

/* 区块标题 */
.section-block {
  margin-bottom: var(--space-md);
}

.section-block .section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--neutral-700);
  margin-bottom: var(--space-sm);
  padding-left: 0;
}

/* 网格布局 */
.grid-2 {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: var(--space-sm);
}

.grid-item {
  background: var(--neutral-0);
  border-radius: var(--radius-md);
  padding: var(--space-md);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-sm);
  transition: all 200ms ease;
  aspect-ratio: 1;
}

.grid-item:active {
  transform: scale(0.98);
  box-shadow: var(--shadow-md);
}

.grid-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: var(--radius-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: var(--space-sm);
}

.grid-icon text {
  font-size: 48rpx;
}

.text-primary {
  color: var(--primary-600);
}

.text-success {
  color: var(--success-600);
}

.grid-label {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--neutral-700);
}

/* 常用分类横向滚动 */
.category-scroll {
  white-space: nowrap;
}

.category-list {
  display: flex;
  gap: var(--space-xs);
  padding: 4rpx 0;
}

.category-tag {
  display: inline-flex;
  align-items: center;
  padding: 16rpx 24rpx;
  border-radius: var(--radius-full);
  background: var(--neutral-0);
  box-shadow: var(--shadow-sm);
  transition: all 200ms ease;
}

.category-tag:active {
  transform: scale(0.95);
}

.tag-income {
  background: var(--success-100);
}

.tag-expense {
  background: var(--error-100);
}

.category-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.category-name {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--neutral-700);
}

/* 最近账单列表 */
.recent-list {
  background: var(--neutral-0);
  border-radius: var(--radius-md);
  padding: 0 var(--space-md);
  box-shadow: var(--shadow-sm);
}

.expense-item {
  display: flex;
  align-items: center;
  padding: var(--space-sm) 0;
  border-bottom: 2rpx solid var(--neutral-100);
}

.expense-item:last-child {
  border-bottom: none;
}

.expense-item:active {
  opacity: 0.7;
}

.expense-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: var(--space-sm);
  flex-shrink: 0;
}

.expense-info {
  flex: 1;
  min-width: 0;
}

.expense-name {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--neutral-900);
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.expense-meta {
  font-size: 24rpx;
  color: var(--neutral-500);
  margin-top: 4rpx;
  display: block;
}

.expense-amount {
  text-align: right;
  margin-left: var(--space-sm);
}

.amount-value {
  font-size: 32rpx;
  font-weight: 600;
  display: block;
}

.expense-tag {
  font-size: 20rpx;
  color: var(--neutral-500);
  background: var(--neutral-100);
  padding: 4rpx 12rpx;
  border-radius: var(--radius-full);
  margin-top: 4rpx;
  display: inline-block;
}

/* 查看更多 */
.view-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--space-sm) 0;
  border-top: 2rpx solid var(--neutral-100);
}

.view-more .text-caption {
  color: var(--primary-600);
}

.list-arrow {
  font-size: 32rpx;
  color: var(--primary-600);
  margin-left: 8rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--space-xl);
  background: var(--neutral-0);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
}

.empty-icon-text {
  font-size: 96rpx;
  margin-bottom: var(--space-sm);
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--neutral-700);
  margin-bottom: var(--space-xs);
}

.empty-desc {
  font-size: 26rpx;
  color: var(--neutral-500);
}

/* 浮动按钮 */
.fab {
  position: fixed;
  right: var(--space-md);
  bottom: 180rpx;
  width: 112rpx;
  height: 112rpx;
  background: var(--primary-600);
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-lg);
  z-index: 100;
  transition: all 200ms ease;
}

.fab:active {
  transform: scale(0.95);
  background: var(--primary-500);
}

.fab-icon {
  font-size: 56rpx;
  color: var(--neutral-0);
  font-weight: 300;
}

/* 文字工具类 */
.text-warning {
  color: var(--warning-600);
}

.text-income {
  color: var(--success-600);
}

.text-expense {
  color: var(--error-600);
}
