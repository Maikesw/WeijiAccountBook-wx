/* 个人中心 - 优化样式 */

.page-container {
  padding: var(--space-sm);
  padding-bottom: 40rpx;
}

/* 用户信息卡片 */
.user-card {
  background: linear-gradient(135deg, var(--primary-600) 0%, var(--primary-500) 100%);
  border-radius: var(--radius-md);
  padding: var(--space-lg);
  margin-bottom: var(--space-sm);
  box-shadow: var(--shadow-md);
}

.user-header {
  display: flex;
  align-items: center;
  margin-bottom: var(--space-lg);
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: var(--radius-full);
  overflow: hidden;
  margin-right: var(--space-md);
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  background: rgba(255, 255, 255, 0.2);
}

.user-avatar open-data {
  width: 100%;
  height: 100%;
}

.user-name {
  font-size: 40rpx;
  font-weight: 600;
  color: var(--neutral-0);
  display: block;
  margin-bottom: 8rpx;
}

.user-id {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 用户统计 */
.user-stats {
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding-top: var(--space-md);
  border-top: 2rpx solid rgba(255, 255, 255, 0.2);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--neutral-0);
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.2);
}

/* 安全中心入口 */
.security-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--space-md);
  background: var(--neutral-0);
  border-radius: var(--radius-md);
  margin-bottom: var(--space-md);
  box-shadow: var(--shadow-sm);
}

.security-left {
  display: flex;
  align-items: center;
}

.security-icon {
  font-size: 40rpx;
  margin-right: var(--space-sm);
}

.security-text {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--neutral-900);
}

.security-arrow {
  font-size: 36rpx;
  color: var(--neutral-400);
}

/* 区块标题 */
.section-block {
  margin-bottom: var(--space-md);
}

.section-title {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--neutral-500);
  margin-bottom: var(--space-sm);
  margin-left: var(--space-xs);
  display: block;
}

/* 功能列表 */
.func-list {
  background: var(--neutral-0);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
  overflow: hidden;
}

.func-item {
  display: flex;
  align-items: center;
  padding: var(--space-md);
  border-bottom: 2rpx solid var(--neutral-100);
  transition: all 200ms ease;
}

.func-item:last-child {
  border-bottom: none;
}

.func-item:active {
  background: var(--neutral-100);
}

.func-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: var(--space-sm);
  flex-shrink: 0;
}

.func-name {
  flex: 1;
  font-size: 30rpx;
  color: var(--neutral-900);
}

.func-value {
  font-size: 26rpx;
  color: var(--neutral-500);
  margin-right: var(--space-sm);
}

.func-arrow {
  font-size: 36rpx;
  color: var(--neutral-400);
}

/* Switch样式 */
.func-item switch {
  margin-left: auto;
}

/* 危险操作区 */
.danger-zone {
  margin-top: var(--space-lg);
  margin-bottom: var(--space-md);
}

.btn-danger {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: transparent;
  border: 2rpx solid var(--error-600);
  color: var(--error-600);
  font-size: 30rpx;
  border-radius: var(--radius-sm);
}

.btn-danger::after {
  border: none;
}

.btn-danger:active {
  background: var(--error-100);
}

/* 底部信息 */
.footer {
  text-align: center;
  padding: var(--space-md) 0;
}

.footer-links {
  font-size: 26rpx;
  color: var(--primary-600);
  margin-bottom: var(--space-xs);
  display: block;
}

.footer-links text {
  margin: 0 var(--space-xs);
}

.footer-links .divider {
  color: var(--neutral-300);
}

.footer-copyright {
  font-size: 22rpx;
  color: var(--neutral-400);
}

/* 弹窗 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  opacity: 0;
  visibility: hidden;
  transition: all 300ms ease;
  z-index: 1000;
}

.modal-show {
  opacity: 1;
  visibility: visible;
}

.modal-content {
  width: 100%;
  max-height: 80vh;
  background: var(--neutral-0);
  border-radius: var(--radius-lg) var(--radius-lg) 0 0;
  padding: var(--space-md);
  transform: translateY(100%);
  transition: transform 300ms ease;
}

.modal-show .modal-content {
  transform: translateY(0);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--space-md);
}

.modal-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--neutral-900);
}

.modal-close {
  font-size: 48rpx;
  color: var(--neutral-400);
  padding: 0 var(--space-sm);
}

/* 字体选项 */
.font-options {
  padding-bottom: var(--space-md);
}

.font-option {
  display: flex;
  align-items: center;
  padding: var(--space-md);
  background: var(--neutral-100);
  border-radius: var(--radius-sm);
  margin-bottom: var(--space-sm);
  transition: all 200ms ease;
}

.font-option:active {
  opacity: 0.8;
}

.font-active {
  background: var(--primary-100);
  border: 2rpx solid var(--primary-600);
}

.font-preview {
  font-weight: 600;
  color: var(--neutral-900);
  margin-right: var(--space-md);
  width: 80rpx;
  text-align: center;
}

.font-label {
  flex: 1;
  font-size: 30rpx;
  color: var(--neutral-700);
}

.check-icon {
  width: 48rpx;
  height: 48rpx;
  background: var(--primary-600);
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--neutral-0);
  font-size: 28rpx;
  font-weight: 600;
}
