/* 记账页 - 优化样式 */

.page-container {
  padding: var(--space-sm);
  padding-bottom: 160rpx;
}

/* 金额输入区 */
.amount-section {
  background: linear-gradient(135deg, var(--primary-600) 0%, var(--primary-500) 100%);
  padding: var(--space-lg);
}

.amount-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: var(--space-sm);
}

.amount-input-wrap {
  display: flex;
  align-items: center;
  margin-bottom: var(--space-md);
}

.currency {
  font-size: 48rpx;
  font-weight: 500;
  color: var(--neutral-0);
  margin-right: var(--space-xs);
}

.amount-input {
  flex: 1;
  font-size: 72rpx;
  font-weight: 700;
  color: var(--neutral-0);
  background: transparent;
  border: none;
  padding: 0;
}

.amount-input::placeholder {
  color: rgba(255, 255, 255, 0.4);
}

.quick-amounts {
  display: flex;
  gap: var(--space-sm);
  flex-wrap: wrap;
}

.quick-amount-tag {
  padding: 12rpx 24rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: var(--radius-full);
  font-size: 26rpx;
  color: var(--neutral-0);
  transition: all 200ms ease;
}

.quick-amount-tag:active {
  background: rgba(255, 255, 255, 0.3);
}

/* 类型切换 */
.type-section {
  padding: var(--space-sm);
}

.type-switch {
  display: flex;
  background: var(--neutral-100);
  border-radius: var(--radius-sm);
  padding: 6rpx;
}

.type-option {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--space-sm) 0;
  border-radius: var(--radius-sm);
  transition: all 300ms ease;
}

.type-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.type-text {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--neutral-700);
}

.type-active {
  background: var(--neutral-0);
  box-shadow: var(--shadow-sm);
}

.type-active .type-text {
  font-weight: 600;
}

.expense-active {
  background: var(--error-100);
}

.expense-active .type-text {
  color: var(--error-600);
}

.income-active {
  background: var(--success-100);
}

.income-active .type-text {
  color: var(--success-600);
}

/* 分类选择 */
.category-section {
  padding: var(--space-md);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--space-md);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--neutral-900);
}

.selected-category {
  font-size: 26rpx;
  color: var(--primary-600);
  font-weight: 500;
}

.category-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: var(--space-sm);
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--space-sm) 0;
  border-radius: var(--radius-sm);
  border: 2rpx solid transparent;
  transition: all 200ms ease;
}

.category-item:active {
  transform: scale(0.95);
}

.category-active {
  background: var(--primary-100);
  border-color: var(--primary-600);
}

.category-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: var(--radius-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  margin-bottom: 12rpx;
}

.category-name {
  font-size: 24rpx;
  color: var(--neutral-700);
}

/* 表单区 */
.form-section {
  padding: 0 var(--space-md);
}

.form-item {
  display: flex;
  align-items: center;
  padding: var(--space-md) 0;
}

.form-label {
  width: 120rpx;
  font-size: 30rpx;
  font-weight: 500;
  color: var(--neutral-900);
  flex-shrink: 0;
}

.form-value {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  font-size: 30rpx;
  color: var(--neutral-700);
}

.form-arrow {
  font-size: 32rpx;
  color: var(--neutral-400);
  margin-left: 12rpx;
}

.form-input {
  flex: 1;
  font-size: 30rpx;
  color: var(--neutral-900);
  text-align: right;
}

.form-input::placeholder {
  color: var(--neutral-400);
}

/* 存钱目标 */
.goal-section {
  padding: var(--space-md);
}

.goal-list {
  margin-top: var(--space-sm);
}

.goal-item {
  display: flex;
  align-items: center;
  padding: var(--space-sm);
  background: var(--neutral-100);
  border-radius: var(--radius-sm);
  margin-bottom: var(--space-xs);
  transition: all 200ms ease;
}

.goal-item:active {
  background: var(--primary-100);
}

.goal-active {
  background: var(--primary-100);
  border: 2rpx solid var(--primary-600);
}

.goal-icon {
  font-size: 40rpx;
  margin-right: var(--space-sm);
}

.goal-info {
  flex: 1;
}

.goal-name {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--neutral-900);
  display: block;
}

.goal-progress {
  font-size: 24rpx;
  color: var(--neutral-500);
  margin-top: 4rpx;
  display: block;
}

.goal-radio {
  width: 44rpx;
  height: 44rpx;
  border: 4rpx solid var(--neutral-300);
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
}

.radio-checked {
  border-color: var(--primary-600);
  background: var(--primary-600);
}

.radio-inner {
  width: 20rpx;
  height: 20rpx;
  background: var(--neutral-0);
  border-radius: var(--radius-full);
}

/* 操作栏 */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: var(--space-md);
  padding-bottom: calc(var(--space-md) + env(safe-area-inset-bottom));
  background: var(--neutral-0);
  box-shadow: 0 -4rpx 16rpx rgba(29, 33, 41, 0.08);
  display: flex;
  gap: var(--space-sm);
  z-index: 100;
}

.save-btn {
  flex: 1;
  min-height: 112rpx;
  font-size: 34rpx;
  font-weight: 600;
}

.delete-btn {
  flex: 0 0 200rpx;
  min-height: 112rpx;
  font-size: 30rpx;
  color: var(--error-600);
  border-color: var(--error-600);
}

.btn-disabled {
  opacity: 0.6;
  background-color: var(--neutral-300) !important;
  color: var(--neutral-500) !important;
  box-shadow: none !important;
}

/* 工具类 */
.divider {
  height: 2rpx;
  background: var(--neutral-100);
  margin: 0;
}
