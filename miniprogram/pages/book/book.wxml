<!-- 账本页 - 优化版本 -->
<view class="page-container">
  <!-- 顶部日期选择器 -->
  <view class="date-selector card">
    <picker mode="date" fields="month" value="{{currentDate}}" end="{{today}}" bindchange="onDateChange">
      <view class="flex-between">
        <view>
          <text class="text-caption">当前月份</text>
          <view class="mt-sm">
            <text class="text-h2">{{currentYear}}年{{currentMonth}}月</text>
            <text class="arrow-icon ml-sm">▼</text>
          </view>
        </view>
        <view class="date-icon">
          <text>📅</text>
        </view>
      </view>
    </picker>
  </view>

  <!-- 核心数据双卡片 -->
  <view class="core-cards">
    <!-- 左侧：当日/当月收支汇总 -->
    <view class="core-card income-card">
      <text class="card-label">本月收支</text>
      <view class="amount-display">
        <text class="amount-main {{monthStats.total >= 0 ? 'text-income' : 'text-expense'}}">
          {{monthStats.total >= 0 ? '+' : ''}}{{monthStats.total}}
        </text>
      </view>
      <view class="amount-sub">
        <text class="income-sub">收入 {{monthStats.income}}</text>
        <text class="expense-sub">支出 {{monthStats.expense}}</text>
      </view>
    </view>

    <!-- 右侧：月度预算进度 -->
    <view class="core-card budget-card">
      <text class="card-label">预算剩余</text>
      <view class="budget-amount">
        <text class="amount-main {{budgetPercent > 90 ? 'text-expense' : (budgetPercent > 60 ? 'text-warning' : 'text-income')}}">
          {{budgetRemaining}}
        </text>
      </view>
      <view class="progress-container">
        <view class="progress-bar">
          <view class="progress-fill {{budgetPercent > 90 ? 'error' : (budgetPercent > 60 ? 'warning' : 'success')}}" 
                style="width: {{budgetPercent}}%"></view>
        </view>
        <text class="progress-text">已用 {{budgetPercent}}%</text>
      </view>
    </view>
  </view>

  <!-- 快捷功能入口 - 2x2网格 -->
  <view class="section-block">
    <text class="section-title">快捷功能</text>
    <view class="grid-2">
      <view class="grid-item" bindtap="onAddExpense">
        <view class="grid-icon bg-primary-light">
          <text class="text-primary">💰</text>
        </view>
        <text class="grid-label">记一笔</text>
      </view>
      <view class="grid-item" bindtap="goToReport">
        <view class="grid-icon" style="background: #E8FFEA;">
          <text class="text-success">📊</text>
        </view>
        <text class="grid-label">收支统计</text>
      </view>
      <view class="grid-item" bindtap="goToBudget">
        <view class="grid-icon" style="background: #FFF7E8;">
          <text style="color: #FF7D00;">🎯</text>
        </view>
        <text class="grid-label">预算管理</text>
      </view>
      <view class="grid-item" bindtap="goToGoal">
        <view class="grid-icon" style="background: #F0F5FF;">
          <text style="color: #165DFF;">🏦</text>
        </view>
        <text class="grid-label">存钱目标</text>
      </view>
    </view>
  </view>

  <!-- 常用分类 - 横向滚动 -->
  <view class="section-block" wx:if="{{quickCategories.length > 0}}">
    <text class="section-title">常用分类</text>
    <scroll-view scroll-x class="category-scroll hide-scrollbar">
      <view class="category-list">
        <view wx:for="{{quickCategories}}" wx:key="name" 
              class="category-tag {{item.type === 'income' ? 'tag-income' : 'tag-expense'}}"
              bindtap="quickAddByCategory" data-category="{{item}}">
          <text class="category-icon">{{item.icon}}</text>
          <text class="category-name">{{item.name}}</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 最近账单 -->
  <view class="section-block">
    <view class="flex-between" style="margin-bottom: 16rpx;">
      <text class="section-title">最近账单</text>
      <text class="text-caption" wx:if="{{recentExpenses.length > 0}}">共{{recentExpenses.length}}笔</text>
    </view>
    
    <view class="recent-list">
      <view wx:for="{{recentExpenses}}" wx:key="_id" 
            class="expense-item" bindtap="onEditExpense" data-id="{{item._id}}">
        <view class="expense-icon" style="background: {{item.bgColor}};">
          <text>{{item.icon}}</text>
        </view>
        <view class="expense-info">
          <text class="expense-name">{{item.event}}</text>
          <text class="expense-meta">{{item.category}} · {{item.displayDate}}</text>
        </view>
        <view class="expense-amount">
          <text class="amount-value {{item.type === 'income' ? 'text-income' : 'text-expense'}}">
            {{item.type === 'income' ? '+' : '-'}}{{item.amount}}
          </text>
          <text class="expense-tag" wx:if="{{item.focus}}">{{item.focus}}</text>
        </view>
      </view>
      
      <!-- 查看更多 -->
      <view class="view-more" wx:if="{{recentExpenses.length >= 5}}" bindtap="viewAllExpenses">
        <text class="text-caption">查看全部账单</text>
        <text class="list-arrow">›</text>
      </view>
    </view>
    
    <!-- 空状态 -->
    <view wx:if="{{recentExpenses.length === 0}}" class="empty-state card">
      <text class="empty-icon-text">📝</text>
      <text class="empty-title">本月还没有记账</text>
      <text class="empty-desc">点击右下角按钮开始记录第一笔</text>
      <button class="btn btn-primary btn-core" style="margin-top: 32rpx; width: 400rpx;" bindtap="onAddExpense">
        记一笔
      </button>
    </view>
  </view>

  <!-- 底部安全区域 -->
  <view style="height: 40rpx;"></view>
</view>

<!-- 浮动添加按钮 -->
<view class="fab" bindtap="onAddExpense">
  <text class="fab-icon">+</text>
</view>
